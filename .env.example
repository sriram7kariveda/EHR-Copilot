# EHR Copilot Configuration

# LLM Provider: "openrouter" (recommended) or "ollama" (local)
EHR__LLM__PROVIDER=openrouter
EHR__LLM__BASE_URL=https://openrouter.ai/api/v1
EHR__LLM__API_KEY=sk-or-v1-your-key-here
EHR__LLM__MODEL=qwen/qwen3-8b

# Alternative: Local Ollama
# EHR__LLM__PROVIDER=ollama
# EHR__LLM__BASE_URL=http://localhost:11434
# EHR__LLM__MODEL=qwen2.5:7b-instruct

# Embedding model (runs locally)
EHR__EMBEDDING__MODEL=NeuML/pubmedbert-base-embeddings

# Logging
EHR__LOGGING__LEVEL=INFO

# Audit
EHR__AUDIT__DB_PATH=./data/audit.db
